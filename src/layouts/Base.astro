---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SoNoted — Your knowledge, unlocked.',
  description = 'AI-powered notes that connect, surface, and work for you.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
