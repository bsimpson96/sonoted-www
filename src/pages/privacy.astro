---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import Section from '../components/ui/Section.astro';
import { InviteSection } from '../components/InviteSection';
---

<Base
  title="Privacy & Security — SoNoted"
  description="Your notes never train our models. Your data stays yours. Here's exactly how we think about privacy at SoNoted."
>
  <!-- Header -->
  <div class="page-header">
    <nav class="nav-bar">
      <a href="/" class="wordmark">SoNoted</a>
      <Button href="/#invite" variant="primary">Get early access</Button>
    </nav>

    <div class="header-content">
      <div class="glow" aria-hidden="true"></div>
      <h1 class="headline">Your notes are yours.<br />We mean that.</h1>
      <p class="subhead">
        Most AI tools train on your data. We don't. Here's exactly how we think about privacy,
        and what we've built to back it up.
      </p>
    </div>
  </div>

  <!-- Core commitments -->
  <Section id="commitments">
    <div class="section-header">
      <h2 class="section-heading">What we commit to.</h2>
    </div>
    <div class="commitment-grid">
      <div class="commitment">
        <div class="commitment-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L4 6v6c0 5.25 3.5 9.74 8 11 4.5-1.26 8-5.75 8-11V6l-8-4z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
        </div>
        <h3 class="commitment-headline">Your notes never train our models</h3>
        <p class="commitment-body">
          Full stop. What you write is not used to improve SoNoted, train AI, or benefit anyone
          other than you. Your notes are processed to serve you, then that's it.
        </p>
      </div>
      <div class="commitment">
        <div class="commitment-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
            <path d="M4.93 4.93a10 10 0 0 0 0 14.14"></path>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            <path d="M8.46 8.46a5 5 0 0 0 0 7.07"></path>
          </svg>
        </div>
        <h3 class="commitment-headline">Bring your own AI key</h3>
        <p class="commitment-body">
          Connect your own OpenAI or Anthropic key. Your notes go directly from your account to
          the model you chose. SoNoted is never in the middle of that conversation.
        </p>
      </div>
      <div class="commitment">
        <div class="commitment-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </div>
        <h3 class="commitment-headline">Your data is portable</h3>
        <p class="commitment-body">
          Export everything, anytime. Your notes came from your life. They leave with you if you
          decide SoNoted isn't right. No hostage-taking.
        </p>
      </div>
      <div class="commitment">
        <div class="commitment-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <h3 class="commitment-headline">No surveillance, ever</h3>
        <p class="commitment-body">
          No tracking pixels, no browser fingerprinting, no third-party analytics watching you
          read this page. We don't need to surveil you to build a good product.
        </p>
      </div>
    </div>
  </Section>

  <!-- What we actually collect -->
  <Section id="what-we-collect">
    <div class="two-col">
      <div class="two-col-text">
        <h2 class="two-col-heading">What we actually collect on this site.</h2>
        <p class="two-col-body">
          Right now, sonoted.ai is a marketing site. We are not yet handling your notes here.
          When you sign up for early access, here's what we collect and why.
        </p>
        <p class="two-col-body">
          Your email address. That's it. We use it to contact you when your spot opens and to
          send the occasional product update. We don't send marketing email to anyone who hasn't
          opted in, and we don't share your address with anyone.
        </p>
        <p class="two-col-body">
          We also temporarily log your IP address to prevent spam submissions -- held in memory
          for one hour, never written to a database.
        </p>
        <a href="/privacy-policy" class="policy-link">Read the full privacy policy</a>
      </div>
      <div class="two-col-card">
        <div class="collect-item">
          <div class="collect-label">We collect</div>
          <ul class="collect-list">
            <li>Your email address (when you sign up)</li>
            <li>Your IP address (temporarily, for rate limiting)</li>
          </ul>
        </div>
        <div class="collect-divider"></div>
        <div class="collect-item">
          <div class="collect-label">We do not collect</div>
          <ul class="collect-list no">
            <li>Cookies or tracking pixels</li>
            <li>Browser fingerprints</li>
            <li>Third-party analytics</li>
            <li>Behavioral data</li>
            <li>Anything we don't need</li>
          </ul>
        </div>
      </div>
    </div>
  </Section>

  <!-- For finance -->
  <Section id="for-finance">
    <div class="finance-callout">
      <div class="finance-callout-text">
        <h2 class="finance-heading">Working in financial services?</h2>
        <p class="finance-body">
          We built SoNoted with regulated professionals in mind. Data sovereignty isn't a
          checkbox for us -- it's how the product works. See how SoNoted fits into a
          compliance-conscious workflow.
        </p>
        <Button href="/finance" variant="ghost">SoNoted for finance</Button>
      </div>
    </div>
  </Section>

  <!-- Invite -->
  <section class="px-4 py-24">
    <InviteSection client:load />
  </section>
</Base>

<style>
  .page-header {
    position: relative;
    min-height: 60dvh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-base);
    overflow: hidden;
  }

  .nav-bar {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  @media (min-width: 768px) {
    .nav-bar {
      padding: 1.75rem 2rem;
    }
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    width: min(600px, 90vw);
    height: min(600px, 90vw);
    background: radial-gradient(ellipse at center, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
    border-radius: 50%;
    filter: blur(40px);
  }

  .header-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    gap: 1.5rem;
  }

  .headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
    max-width: 16ch;
  }

  .subhead {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 48ch;
    margin: 0;
    line-height: 1.6;
  }

  /* Commitments */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .commitment-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .commitment-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .commitment {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .commitment-icon {
    color: var(--color-accent);
  }

  .commitment-headline {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .commitment-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.7;
  }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .two-col {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  .two-col-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }

  .two-col-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .policy-link {
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline-block;
    margin-top: 0.5rem;
  }

  .two-col-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .collect-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .collect-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .collect-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .collect-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    top: 0.2em;
  }

  .collect-list.no li::before {
    content: '✕';
    color: var(--color-text-muted);
  }

  .collect-divider {
    height: 1px;
    background-color: var(--color-border);
  }

  /* Finance callout */
  .finance-callout {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 3rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .finance-callout-text {
    max-width: 52ch;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .finance-heading {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .finance-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }
</style>
